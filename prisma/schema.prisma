generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  
  // Public info
  description    String?
  phone          String?
  website        String?
  logo           String? // URL to logo
  bankName       String?
  bankBin        String?
  bankAccountNumber String?
  bankAccountName String?
  transferNotePrefix String?
  
  // Security
  twoFactorEnabled Boolean  @default(false)
  passwordChangedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  products     Product[]
  sales        Sale[]
  emailConfig  EmailConfig?
}

model EmailConfig {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  gmailEmail   String
  refreshToken String   // Encrypted OAuth refresh token
  isConnected  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String   @unique // Email must be globally unique across all shops
  passwordHash String
  role         String   @default("owner")
  canManageProducts Boolean @default(false)
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sales  Sale[]

  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  priceCents  Int
  costCents   Int      @default(0)
  stockQuantity Int    @default(0)
  category    String?
  description String?
  imageUrl    String?  // Product image URL
  createdAt   DateTime @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  saleItems SaleItem[]

  @@index([tenantId])
}

model Sale {
  id                  String   @id @default(cuid())
  tenantId            String
  userId              String
  subtotalCents       Int
  taxRate             Int      @default(0)
  taxAmountCents      Int      @default(0)
  discountCents       Int      @default(0)
  totalCents          Int
  status              SaleStatus @default(COMPLETED)
  customerEmail       String?
  customerName        String?
  customerPhone       String?
  paymentMethod       String   @default("cash") // cash, card, transfer
  amountReceivedCents Int?     // For cash: amount customer paid
  notes               String?  // Transaction notes
  createdAt           DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  items  SaleItem[]

  @@index([tenantId])
  @@index([status])
}

enum SaleStatus {
  COMPLETED
  VOIDED
  REFUNDED
  REFUND
}

model SaleItem {
  id            String @id @default(cuid())
  saleId        String
  productId     String?
  productName   String   @default("")
  productCategory String?
  quantity      Int
  unitCostCents Int    @default(0)
  unitPriceCents Int
  lineTotalCents Int

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([productId])
}
